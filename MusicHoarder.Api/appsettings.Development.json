{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "MusicEnricher": {
    "SourceDirectory": "/Volumes/music",
    "DestinationDirectory": "//nas/music-clean",
