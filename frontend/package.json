    "prettier-plugin-tailwindcss": "^0.6.10",
    "semantic-release": "^25.0.0",
    "svelte": "^5.55.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0",
