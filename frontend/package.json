{
  "name": "musichoarder-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "start:prod": "bun build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint .",
    "test": "svelte-kit sync && vitest run",
    "test:watch": "svelte-kit sync && vitest",
    "format": "prettier --write .",
    "release": "semantic-release",
    "release:dry": "semantic-release --dry-run --no-ci"
  },
  "dependencies": {
    "@lucide/svelte": "^1.17.0",
    "@opentelemetry/auto-instrumentations-node": "^0.76.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.218.0",
    "@opentelemetry/sdk-node": "^0.218.0",
    "bits-ui": "^2.18.0",
    "clsx": "^2.1.1",
    "import-in-the-middle": "^3.0.1",
    "mode-watcher": "^1.1.0",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@internationalized/date": "^3.12.2",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/github": "^12.0.8",
    "@semantic-release/release-notes-generator": "^14.1.1",
    "@sveltejs/adapter-node": "^5.5.0",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^15.14.0",
    "paneforge": "^1.0.2",
    "prettier": "^3.4.0",
    "prettier-plugin-svelte": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "semantic-release": "^25.0.0",
    "svelte": "^5.56.0",
    "svelte-check": "^4.1.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vite": "^8",
    "vitest": "^4.1.7"
  }
}
