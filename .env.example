# MusicHoarder configuration. Copy this file to `.env` next to docker-compose.yml and fill in
# the REQUIRED values below. Everything under "Optional" can be left as-is to start; the app
# degrades gracefully without the optional integrations.
#
# Full guide: docs/SELF_HOSTING.md

# ─── Required ────────────────────────────────────────────────────────────────────────────────

# Postgres password for the bundled database. Use a long random string.
POSTGRES_PASSWORD=a-strong-random-password

# Absolute paths on the HOST to your music. Source is mounted read-only and is never modified;
# the cleaned, organized copy is written to the destination. On a NAS, point these at your
# dataset/share mount points.
MUSIC_SOURCE_PATH=/mnt/music/source
MUSIC_DESTINATION_PATH=/mnt/music/clean

# Email of the owner (admin) account. Sign in with this address via the magic-link flow.
OWNER_EMAIL=you@example.com

# The PUBLIC URL you reach MusicHoarder at — i.e. the address your reverse proxy serves
# (https://music.example.com). The app itself only speaks plain HTTP (frontend :3000, API
# :5050); terminate TLS at your own proxy. Magic-link emails and Spotify redirects are built
# from this, so it must match what you actually visit. For LAN-only use, set it to
# http://<server-ip>:3000.
PUBLIC_BASE_URL=https://music.example.com

# ─── Optional ────────────────────────────────────────────────────────────────────────────────

# Pin a specific release instead of tracking :latest, e.g. MUSICHOARDER_VERSION=v1.9.1.
# See https://github.com/Jeffreyyvdb/MusicHoarder/releases
MUSICHOARDER_VERSION=latest

# AcoustID API key — enables audio-fingerprint identification (strongly recommended; without
# it most tracks land in the review queue instead of matching). Free key: https://acoustid.org/new-application
ACOUSTID_API_KEY=

# Spotify integration (metadata enrichment + OAuth). Leave blank to disable.
# Register an app at https://developer.spotify.com/dashboard and add this redirect URI:
#   <PUBLIC_BASE_URL>/api/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Read-only demo account address. Defaults to demo@musichoarder.local.
DEMO_USER_EMAIL=demo@musichoarder.local

# Resend for sending magic-link emails. When blank, the sign-in link is printed to the API logs
# (`docker compose logs musichoarder`) instead — fine for first boot / single-user setups.
# Get a key at https://resend.com; the from-address must be on a domain verified there.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=auth@example.com

# Optional AI quality grading (OpenAI-compatible; OpenRouter by default). Blank key → no-op.
QUALITY_GRADING_API_KEY=
QUALITY_GRADING_MODEL=deepseek/deepseek-v4-flash
QUALITY_GRADING_BASE_URL=https://openrouter.ai/api/v1

# Optional self-hosted Umami analytics (frontend). Leave blank to disable. Read at runtime, so
# changing these is just an env change + restart, no rebuild. PUBLIC_UMAMI_SRC must be the full
# tracker URL ending in /script.js (not the dashboard root).
PUBLIC_UMAMI_SRC=
PUBLIC_UMAMI_WEBSITE_ID=
PUBLIC_UMAMI_RECORDER_SRC=
