POSTGRES_PASSWORD=a-strong-random-password
ACOUSTID_API_KEY=accoustid-api-key
MUSIC_SOURCE_PATH=path-to-source
MUSIC_DESTINATION_PATH=path-to-destination

# Spotify integration (optional — leave blank to disable Spotify features)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Auth (magic-link sign-in)
# Required: email of the owner account. Used for magic-link sign-in to the admin user.
OWNER_EMAIL=you@example.com
# Optional: address of the demo (read-only) account. Defaults to demo@musichoarder.local.
DEMO_USER_EMAIL=demo@musichoarder.local

# Resend for magic-link emails. Optional — falls back to logging the link to the API logs
# (visible via `docker compose logs musichoarder`) when blank.
RESEND_API_KEY=
RESEND_FROM_ADDRESS=auth@example.com

# Required: the public URL the frontend is served from (HTTPS in prod). Magic-link emails point
# at <PUBLIC_BASE_URL>/auth/callback?token=... so this must match what users actually visit.
PUBLIC_BASE_URL=https://musichoarder.example.com

# Optional: self-hosted Umami analytics (frontend). Leave blank to disable.
# Must be set at build time for SvelteKit to inline.
PUBLIC_UMAMI_SRC=""
PUBLIC_UMAMI_RECORDER_SRC=""
PUBLIC_UMAMI_WEBSITE_ID=""
